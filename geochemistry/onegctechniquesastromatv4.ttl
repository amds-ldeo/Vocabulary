<https://w3id.org/geochem/1.0/analyticalmethod/emissionspectrometry>
  rdf:type rdfs:Resource ;
  rdf:type skos:Concept ;
  dcterms:contributor <http://editor.vocabs.ardc.edu.au/user/e304bbf8-a56d-49da-854e-8b8046dc2057> ;
  dcterms:modified "2025-10-13T07:37:27.910Z"^^xsd:dateTime ;
  dcterms:modified "2025-10-13T07:38:06.994Z"^^xsd:dateTime ;
  dcterms:source <https://w3id.org/geochem/1.0/agent/astromat> ;
  dcterms:source <https://w3id.org/geochem/1.0/agent/petdb> ;
  dcterms:source "https://en.wikipedia.org/wiki/Atomic_emission_spectroscopy" ;
  rdfs:isDefinedBy <https://w3id.org/geochem/1.1/analyticalmethod/method> ;
  rdfs:label "Emission spectrometry"@en ;
  rdfs:seeAlso <https://w3id.org/geochem/1.1/analyticalmethod/method> ;
  skos:altLabel "DIRECT READING OPTICAL EMISSIONS SPECTROSCOPY"@en ;
  skos:altLabel "DROES"@en ;
  skos:broader <https://w3id.org/geochem/1.0/analyticalmethod/opticalspectrometry> ;
  skos:changeNote [
      dcterms:created "2025-10-13T07:38:06.971Z"^^xsd:dateTime ;
      dcterms:creator <http://editor.vocabs.ardc.edu.au/user/e304bbf8-a56d-49da-854e-8b8046dc2057> ;
      dcterms:title "prefLabel update" ;
      rdfs:comment "updated prefLable to &apos;Atomic emission spectrometry&apos;" ;
    ] ;
  skos:definition "is a method of chemical analysis that uses the intensity of light emitted from a flame, plasma, arc, or spark at a particular wavelength to determine the quantity of an element in a sample. The wavelength of the atomic spectral line in the emission spectrum gives the identity of the element while the intensity of the emitted light is proportional to the number of atoms of the element. The sample may be excited by various methods: flame, inductively coupled plasma, and spark being the most common. (https://en.wikipedia.org/wiki/Atomic_emission_spectroscopy)"@en ;
  skos:inScheme <https://w3id.org/geochem/1.1/analyticalmethod/method> ;
  skos:narrower <https://w3id.org/geochem/1.0/analyticalmethod/fireassayemissionspectrometry> ;
  skos:narrower <https://w3id.org/geochem/1.0/analyticalmethod/flameemissionspectrometry> ;
  skos:narrower <https://w3id.org/geochem/1.0/analyticalmethod/laserinducedbreakdownspectrometry> ;
  skos:narrower <https://w3id.org/geochem/1.0/analyticalmethod/opticalemissionspectrometry> ;
  skos:narrower <https://w3id.org/geochem/1.0/analyticalmethod/plasmaemissionspectrometry> ;
  skos:narrower <https://w3id.org/geochem/1.0/analyticalmethod/ultravioletemissionspectrometry> ;
  skos:notation "E-S" ;
  skos:prefLabel "Atomic emission spectrometry"@en ;
.
