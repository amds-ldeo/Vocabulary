  rdf:type rdfs:Resource ;
  rdf:type skos:Concept ;
  dcterms:source <https://w3id.org/geochem/1.0/analyticalmethod/smraddgencategory> ;
  rdfs:isDefinedBy <https://w3id.org/geochem/1.1/analyticalmethod/method> ;
  rdfs:label "X-ray spectrometry"@en ;
  rdfs:seeAlso <https://w3id.org/geochem/1.1/analyticalmethod/method> ;
  skos:broader <https://w3id.org/geochem/1.0/analyticalmethod/photonspectrometry> ;
  skos:definition "Analysis of the energy distribution of photons in the X-ray wavelength range that are emitted from a sample."@en ;
  skos:inScheme <https://w3id.org/geochem/1.1/analyticalmethod/method> ;
  skos:narrower <https://w3id.org/geochem/1.0/analyticalmethod/broadbeamxrayspectrometry> ;
  skos:narrower <https://w3id.org/geochem/1.0/analyticalmethod/electroninducedxrayspectrometry> ;
