  dcterms:creator <https://w3id.org/geochem/1.0/agent/astromat> ;
  dcterms:creator <https://w3id.org/geochem/1.0/agent/georoc> ;
  dcterms:creator <https://w3id.org/geochem/1.0/agent/geox> ;
