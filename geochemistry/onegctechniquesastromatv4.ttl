<https://w3id.org/geochem/1.0/analyticalmethod/pyrolysisgaschromatographyflameionizationdetection>
  rdf:type rdfs:Resource ;
  rdf:type skos:Concept ;
  dcterms:contributor <http://editor.vocabs.ardc.edu.au/user/e304bbf8-a56d-49da-854e-8b8046dc2057> ;
  dcterms:modified "2025-12-08T03:39:23.975Z"^^xsd:dateTime ;
  dcterms:modified "2025-12-08T03:39:34.977Z"^^xsd:dateTime ;
  dcterms:source <https://doi.org/10.1515/pac-2017-0111> ;
  dcterms:source <https://w3id.org/geochem/1.0/agent/geox> ;
  rdfs:isDefinedBy <https://w3id.org/geochem/1.1/analyticalmethod/method> ;
  rdfs:label "Pyrolysis gas chromatography flame ionization detection"@en ;
  rdfs:seeAlso <https://w3id.org/geochem/1.1/analyticalmethod/method> ;
  skos:broader <https://w3id.org/geochem/1.0/analyticalmethod/gaschromatographyflameionizationdetection> ;
  skos:broader <https://w3id.org/geochem/1.0/analyticalmethod/pyrolysisgaschromatography> ;
  skos:changeNote [
      dcterms:created "2025-12-08T03:39:34.955Z"^^xsd:dateTime ;
      dcterms:creator <http://editor.vocabs.ardc.edu.au/user/e304bbf8-a56d-49da-854e-8b8046dc2057> ;
      dcterms:title "updated Definition" ;
      rdfs:comment "" ;
    ] ;
  skos:definition "Technique that uses a flame ionization detector (FID) to measure the concentration of organic species in a gas stream emerging from the column. An FID typically uses a Hydrogen/Air flame into which the sample is passed to oxidize organic molecules and produces electrically charged particles (ions). The ions are collected and produce an electrical signal which is then measured. (Source: IUPAC; https://doi.org/10.1515/pac-2017-0111)"@en ;
  skos:inScheme <https://w3id.org/geochem/1.1/analyticalmethod/method> ;
  skos:notation "PY-GC-FID" ;
  skos:prefLabel "Pyrolysis gas chromatography flame ionization detection"@en ;
.
