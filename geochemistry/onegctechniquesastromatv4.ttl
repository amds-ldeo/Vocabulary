  skos:narrower <https://w3id.org/geochem/1.0/analyticalmethod/xrayabsorptionspectrometry> ;
  skos:narrower <https://w3id.org/geochem/1.0/analyticalmethod/xrayfluorescencespectrometry> ;
  skos:notation "X-S" ;
  skos:prefLabel "X-ray spectrometry"@en ;
.
