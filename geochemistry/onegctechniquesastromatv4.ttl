      rdfs:comment "" ;
    ] ;
  skos:changeNote [
      dcterms:created "2025-12-08T05:58:22.816Z"^^xsd:dateTime ;
      dcterms:creator <http://editor.vocabs.ardc.edu.au/user/e304bbf8-a56d-49da-854e-8b8046dc2057> ;
