  skos:altLabel "LASER-MICROPROBE ANALYSIS"@en ;
  skos:altLabel "SINGLE CRYSTAL LASER FUSION ANALYSIS"@en ;
  skos:altLabel "SINGLE CRYSTAL LASER FUSION TECHNIQUE"@en ;
  skos:broader <https://w3id.org/geochem/1.0/analyticalmethod/inductivelycoupledplasmamassspectrometry> ;
  skos:changeNote [
      dcterms:created "2025-12-08T04:31:08.019Z"^^xsd:dateTime ;
