  skos:notation "DDA" ;
  skos:prefLabel "Deuteron activation analysis"@en ;
.
<https://w3id.org/geochem/1.0/analyticalmethod/dietrichfruhlingcalcimetry>
  rdf:type rdfs:Resource ;
  rdf:type skos:Concept ;
  dcterms:source <https://w3id.org/geochem/1.0/agent/georoc> ;
  dcterms:source "https://www.gabbrielli.com/en/prodotto/dietrich-fruhling-calcimeter/" ;
